    <script>
        (function () {
            var toggles = Array.prototype.slice.call(document.querySelectorAll('.plugin-roundrobin-config .rr-toggle'));
            if (!toggles.length) {
                return;
            }

            function refreshLabel(cb) {
                var label = document.querySelector('label[for="' + cb.id + '"].rr-toggle-label');
                if (!label) {
                    return;
                }
                label.textContent = cb.checked ? cb.dataset.rrOn : cb.dataset.rrOff;
            }

            toggles.forEach(function (cb) {
                cb.addEventListener('change', function () { refreshLabel(cb); });
                refreshLabel(cb);
            });

            var selectAll = document.getElementById('rr_select_all_sw');
            if (!selectAll) {
                return;
            }

            var selectable = toggles.filter(function (cb) { return !cb.disabled; });

            function syncSelectAllState() {
                if (!selectable.length) {
                    selectAll.checked = false;
                    return;
                }
                var checkedCount = selectable.filter(function (cb) { return cb.checked; }).length;
                // Only two states: on when every row is on, off otherwise (no indeterminate — avoids a different track colour).
                selectAll.checked = checkedCount === selectable.length && checkedCount > 0;
            }

            selectAll.addEventListener('change', function () {
                var target = selectAll.checked;
                selectable.forEach(function (cb) {
                    if (cb.checked !== target) {
                        cb.checked = target;
                        refreshLabel(cb);
                    }
                });
            });

            selectable.forEach(function (cb) {
                cb.addEventListener('change', syncSelectAllState);
            });

            syncSelectAllState();
        })();
    </script>

