{#
 # Round robin plugin configuration — scoped under .plugin-roundrobin-config (see printConfigPage).
 #}
<style>
    .plugin-roundrobin-config .plugin-roundrobin-config__section-card {
        overflow: visible;
    }
    .plugin-roundrobin-config .plugin-roundrobin-config__section-head {
        position: relative;
        display: flex;
        align-items: stretch;
        flex-wrap: nowrap;
        min-height: 2rem;
        padding-block: 0.3rem;
        overflow: visible;
        background: linear-gradient(180deg, #e9f2fa 0%, #ddeaf5 100%);
        border: 1px solid #c5d9ec;
        border-bottom: none;
        border-radius: var(--tblr-border-radius-lg, 0.375rem) var(--tblr-border-radius-lg, 0.375rem) 0 0;
    }
    .plugin-roundrobin-config .plugin-roundrobin-config__section-head > .ribbon {
        position: absolute;
        left: 0.85rem;
        top: -0.25rem;
        z-index: 2;
    }
    .plugin-roundrobin-config .plugin-roundrobin-config__head-main {
        display: flex;
        align-items: center;
        align-self: stretch;
        flex: 1;
        min-width: 0;
        margin: 0;
        margin-inline-start: 3.55rem;
        padding: 0 1rem 0 0.1rem;
    }
    .plugin-roundrobin-config .plugin-roundrobin-config__section-title {
        margin: 0;
        font-size: 1rem;
        font-weight: 600;
        line-height: 1.35;
        color: #184d7a;
        letter-spacing: 0.01em;
    }
    .plugin-roundrobin-config .plugin-roundrobin-config__section-body {
        border: 1px solid #c5d9ec;
        border-top: 1px solid #b8d4ea;
    }
    .plugin-roundrobin-config .plugin-roundrobin-history .rr-list-page-head {
        position: relative;
        display: flex;
        align-items: center;
        flex-wrap: nowrap;
        min-height: 2.45rem;
        padding-block: 0.45rem;
        overflow: visible;
        background: linear-gradient(180deg, #e9f2fa 0%, #ddeaf5 100%);
        border: 1px solid #c5d9ec;
        border-bottom: none;
        border-radius: var(--tblr-border-radius-lg, 0.375rem) var(--tblr-border-radius-lg, 0.375rem) 0 0;
    }
    .plugin-roundrobin-config .plugin-roundrobin-history .rr-list-page-head > .ribbon {
        position: absolute;
        left: 0.85rem;
        top: -0.28rem;
        z-index: 2;
        padding-bottom: 0.8rem;
    }
    .plugin-roundrobin-config .plugin-roundrobin-history .rr-list-page-head-main {
        display: flex;
        align-items: center;
        align-self: stretch;
        flex: 1;
        margin-inline-start: 3.55rem;
        padding: 0 1rem 0 0.1rem;
    }
    .plugin-roundrobin-config .plugin-roundrobin-history .rr-list-page-title {
        margin: 0;
        font-size: 1rem;
        font-weight: 600;
        line-height: 1.35;
        color: #184d7a;
    }
    .plugin-roundrobin-config #plugin-rr-category-table thead th {
        font-family: var(--tblr-body-font-family, inter, -apple-system, blinkmacsystemfont, "Segoe UI", helvetica, arial, sans-serif);
        font-size: 11px;
        font-weight: 600;
        line-height: 1.35;
        letter-spacing: 0.055em;
        text-transform: uppercase;
        color: #64748b;
        font-feature-settings: "cv03", "cv04", "cv11", "liga" 0;
        border-bottom-width: 1px;
        border-left: none;
        border-right: none;
        padding: 0.55rem 0.65rem;
        vertical-align: middle;
    }
    .plugin-roundrobin-config #plugin-rr-category-table tbody td {
        font-family: var(--tblr-body-font-family, inter, -apple-system, blinkmacsystemfont, "Segoe UI", helvetica, arial, sans-serif);
        font-size: 13px;
        font-weight: 400;
        line-height: 1.45;
        color: rgb(55, 65, 81);
        vertical-align: middle;
        padding: 0.55rem 0.65rem;
        border-left: none;
        border-right: none;
    }
    .plugin-roundrobin-config .rr-category-row.rr-category-row--hidden,
    .plugin-roundrobin-config .rr-category-row.rr-category-row--paged-out {
        display: none;
    }
    /* Item links — follow GLPI/Tabler link tokens (readable vs. pale link utilities) */
    .plugin-roundrobin-config #plugin-rr-category-table tbody td a.rr-item-link {
        color: var(--bs-link-color, var(--tblr-link-color));
        font-weight: 500;
        text-decoration: none;
    }
    .plugin-roundrobin-config #plugin-rr-category-table tbody td a.rr-item-link:hover,
    .plugin-roundrobin-config #plugin-rr-category-table tbody td a.rr-item-link:focus {
        color: var(--bs-link-hover-color, var(--tblr-link-hover-color));
        text-decoration: underline;
    }
    .plugin-roundrobin-config .rr-category-intro {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
        padding: 0.75rem 1rem;
        border-top: 1px solid var(--tblr-border-color, #e2e8f0);
    }
    .plugin-roundrobin-config .rr-category-intro__text {
        margin: 0;
        min-width: 0;
        flex: 1 1 auto;
    }
    .plugin-roundrobin-config .rr-category-filters {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        flex: 0 0 auto;
    }
    .plugin-roundrobin-config .rr-member-filter-group,
    .plugin-roundrobin-config .rr-category-search-group {
        display: flex;
        align-items: stretch;
        width: auto;
        max-width: 100%;
        min-height: calc(1.5em + 0.75rem + 2px);
        background: #fff;
        border: 1px solid var(--tblr-border-color, #e2e8f0);
        border-radius: var(--tblr-border-radius, 0.375rem);
        overflow: visible;
        transition: border-color 0.15s ease, box-shadow 0.15s ease;
    }
    .plugin-roundrobin-config .rr-member-filter-group {
        width: fit-content;
        max-width: 100%;
        position: relative;
    }
    .plugin-roundrobin-config .rr-category-search-group {
        width: fit-content;
        max-width: 100%;
    }
    .plugin-roundrobin-config .rr-member-filter-group:focus-within,
    .plugin-roundrobin-config .rr-category-search-group:focus-within {
        border-color: #7eb8e8;
        box-shadow: 0 0 0 0.2rem rgba(24, 77, 122, 0.12);
    }
    .plugin-roundrobin-config .rr-member-filter-group__icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex: 0 0 1.65rem;
        color: var(--bs-link-color, var(--tblr-link-color));
        background: transparent;
    }
    .plugin-roundrobin-config .rr-member-filter-group__icon .ti {
        color: inherit;
    }
    .plugin-roundrobin-config .rr-custom-select {
        position: relative;
        flex: 0 0 auto;
        width: auto;
        min-width: 0;
    }
    .plugin-roundrobin-config .rr-custom-select__trigger {
        display: inline-flex;
        align-items: center;
        justify-content: flex-start;
        gap: 0.2rem;
        width: auto;
        max-width: 100%;
        min-height: calc(1.5em + 0.75rem);
        padding: 0.375rem 0.35rem 0.375rem 0;
        border: 0;
        background: transparent;
        box-shadow: none;
        font-size: 0.8125rem;
        font-weight: 400;
        line-height: 1.35;
        color: rgb(55, 65, 81);
        text-align: left;
        cursor: pointer;
    }
    .plugin-roundrobin-config .rr-custom-select__trigger:hover,
    .plugin-roundrobin-config .rr-custom-select__trigger:focus {
        color: rgb(55, 65, 81);
        outline: none;
    }
    .plugin-roundrobin-config .rr-custom-select__label {
        flex: 0 1 auto;
        white-space: nowrap;
    }
    .plugin-roundrobin-config .rr-custom-select__caret {
        flex-shrink: 0;
        font-size: 0.8rem;
        color: #94a3b8;
        transition: transform 0.15s ease;
    }
    .plugin-roundrobin-config .rr-custom-select.is-open .rr-custom-select__caret {
        transform: rotate(180deg);
    }
    .plugin-roundrobin-config .rr-custom-select__menu {
        position: absolute;
        top: 100%;
        left: 0;
        z-index: 20;
        display: block;
        width: max-content;
        min-width: 100%;
        max-width: min(100vw, 24rem);
        margin: 0.125rem 0 0;
        padding: var(--tblr-dropdown-padding-y, 0.25rem) 0;
        list-style: none;
    }
    .plugin-roundrobin-config .rr-custom-select__menu[hidden] {
        display: none;
    }
    .plugin-roundrobin-config .rr-custom-select__menu .dropdown-item {
        display: block;
        width: auto;
        min-width: 100%;
        padding: var(--tblr-dropdown-item-padding-y, 0.25rem) var(--tblr-dropdown-item-padding-x, 0.75rem);
        font-size: 0.8125rem;
        line-height: 1.35;
        white-space: nowrap;
        border: 0;
        border-radius: 0;
        text-align: left;
    }
    .plugin-roundrobin-config .rr-custom-select__menu .dropdown-item.active,
    .plugin-roundrobin-config .rr-custom-select__menu .dropdown-item:active {
        font-weight: 500;
    }
    .plugin-roundrobin-config .rr-category-search-group .form-control {
        flex: 0 0 auto;
        width: auto;
        min-width: 0;
        max-width: 100%;
        font-size: 0.8125rem;
        padding: 0.375rem 0 0.375rem 0.5rem;
        border: 0;
        background: transparent;
        box-shadow: none;
    }
    .plugin-roundrobin-config .rr-category-search-group .form-control:focus {
        border: 0;
        box-shadow: none;
    }
    .plugin-roundrobin-config .rr-category-search-group .form-control::placeholder {
        color: #94a3b8;
    }
    .plugin-roundrobin-config .rr-category-search-group__action {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex: 0 0 1.15rem;
        padding: 0 0.15rem 0 0;
        border: 0;
        background: transparent;
    }
    .plugin-roundrobin-config .rr-category-search-group .btn-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        min-height: calc(1.5em + 0.75rem);
        margin: 0;
        padding: 0;
        color: var(--bs-link-color, var(--tblr-link-color));
        text-decoration: none;
    }
    .plugin-roundrobin-config .rr-category-search-group .btn-link:hover,
    .plugin-roundrobin-config .rr-category-search-group .btn-link:focus,
    .plugin-roundrobin-config .rr-category-search-group .btn-link:active,
    .plugin-roundrobin-config .rr-category-search-group .btn-link:focus-visible {
        color: var(--bs-link-color, var(--tblr-link-color));
        text-decoration: none;
        box-shadow: none;
        outline: none;
    }
    .plugin-roundrobin-config .rr-category-search-group .btn-link .ti {
        color: inherit;
        font-size: 0.95rem;
    }
    @media (max-width: 767.98px) {
        .plugin-roundrobin-config .rr-category-intro {
            flex-wrap: wrap;
            align-items: flex-start;
        }
        .plugin-roundrobin-config .rr-category-filters {
            width: 100%;
            flex-wrap: wrap;
        }
        .plugin-roundrobin-config .rr-member-filter-group,
        .plugin-roundrobin-config .rr-category-search-group {
            flex: 1 1 100%;
            width: 100%;
        }
    }
    .plugin-roundrobin-config #rr_category_pagination .page-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 2rem;
        min-height: 2rem;
        padding: 0.25rem 0.65rem;
        line-height: 1;
    }
    .plugin-roundrobin-config #rr_category_pagination .page-link .ti {
        margin: 0;
    }
    .plugin-roundrobin-config .rr-category-scroll.is-scrollable {
        max-height: min(60vh, 20rem);
        overflow: auto;
    }
    .plugin-roundrobin-config .rr-category-scroll.is-scrollable #plugin-rr-category-table thead th {
        position: sticky;
        top: 0;
        z-index: 2;
        background: var(--tblr-table-head-bg, #f8fafc);
        box-shadow: inset 0 -1px 0 var(--tblr-border-color, #e2e8f0);
    }
    .plugin-roundrobin-config .rr-category-no-results {
        display: none;
        padding: 1.25rem 1rem;
    }
    .plugin-roundrobin-config .rr-category-no-results.is-visible {
        display: block;
    }
</style>

<header class="plugin-roundrobin-config__page-title mb-4 text-center">
    <h1 class="display-5 fw-bold text-body mb-0">{{ __('RoundRobin', 'roundrobin') }}</h1>
</header>

<form method="post"
      action=""
      class="plugin-roundrobin-config__form"
      data-persisted-search="{{ persisted_search|e('html_attr') }}"
      data-persisted-page="{{ persisted_page }}"
      data-persisted-member-filter="{{ persisted_member_filter|e('html_attr') }}">
    {{ csrf_token|raw }}
    <input type="hidden" name="rr_list_limit" id="rr_list_limit_persist" value="{{ default_list_limit }}"/>
    <input type="hidden" name="rr_category_search_persist" id="rr_category_search_persist" value="{{ persisted_search|e('html_attr') }}"/>
    <input type="hidden" name="rr_current_page" id="rr_current_page_persist" value="{{ persisted_page }}"/>
    <input type="hidden" name="rr_member_filter" id="rr_member_filter_persist" value="{{ persisted_member_filter|e('html_attr') }}"/>

    {# —— Group assignment behaviour —— #}
    <div class="card shadow-sm mb-3 border-0 rounded plugin-roundrobin-config__section-card">
        <div class="plugin-roundrobin-config__section-head">
            <div class="ribbon ribbon-bookmark ribbon-top ribbon-start bg-blue s-1 align-self-start" aria-hidden="true">
                <i class="ti ti-adjustments-horizontal fa-2x"></i>
            </div>
            <div class="plugin-roundrobin-config__head-main">
                <h2 class="plugin-roundrobin-config__section-title">{{ __('Group assignment behaviour', 'roundrobin') }}</h2>
            </div>
        </div>
        <div class="card-body plugin-roundrobin-config__section-body rounded-0">
            <div class="row g-3">
                <div class="col-12">
                    <p class="small text-muted mb-2">{{ __('Assign the rotated technician plus the technician group linked to the category when checked.', 'roundrobin') }}</p>

                    <input type="hidden" name="auto_assign_group" value="0"/>
                    <div class="form-check form-switch">
                        <input class="form-check-input"
                               role="switch"
                               type="checkbox"
                               id="rr_assign_group_sw"
                               name="auto_assign_group"
                               value="1"
                               {% if auto_assign_group %}checked="checked"{% endif %}
                               {% if not can_write %}disabled{% endif %} />
                        <label class="form-check-label" for="rr_assign_group_sw">{{ __('Also assign tickets to this category\'s technician group', 'roundrobin') }}</label>
                    </div>
                </div>
            </div>
        </div>
    </div>

{% if centralInterfaceCheck %}

    {% if config_warnings is defined and config_warnings is not empty %}
        <div class="alert alert-important alert-warning alert-dismissible mb-3" role="alert">
            <div class="d-flex">
                <div>
                    <i class="ti ti-alert-triangle icon alert-icon ms-2 me-3 mt-1" style="font-size:1.5rem;" aria-hidden="true"></i>
                </div>
                <div>
                    {% for w in config_warnings %}
                        {% if not loop.first %}<br>{% endif %}{{ w }}{% endfor %}
                </div>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="{{ __('Close')|e('html_attr') }}"></button>
        </div>
    {% endif %}

        <div class="card border-0 shadow-sm mb-3 plugin-roundrobin-history" style="overflow: visible;">
            <div class="rr-list-page-head">
                <div class="ribbon ribbon-bookmark ribbon-top ribbon-start bg-blue s-1 align-self-start" aria-hidden="true">
                    <i class="ti ti-category fa-2x"></i>
                </div>
                <div class="rr-list-page-head-main">
                    <h2 class="rr-list-page-title mb-0">{{ __('Categories & technician groups', 'roundrobin') }}</h2>
                </div>
            </div>

            <div class="card-body p-0 border-top">
                {% if settings is empty %}
                    <p class="text-muted small px-3 pt-3 mb-0 pb-3">
                        {{ __('New tickets pick the next technician from the category technician group.', 'roundrobin') }}
                    </p>
                    <p class="text-muted p-3 mb-0 border-top">{{ __('No ITIL categories found.', 'roundrobin') }}</p>
                {% else %}
                    {% set search_placeholder = __('Search for category or group', 'roundrobin') %}
                    {% set no_group_label = __('No technician group assigned', 'roundrobin') %}
                    <div class="rr-category-intro">
                        <p class="text-muted small rr-category-intro__text">
                            {{ __('New tickets pick the next technician from the category technician group.', 'roundrobin') }}
                        </p>
                        <div class="rr-category-filters">
                            <div class="rr-member-filter-group">
                                <span class="rr-member-filter-group__icon" aria-hidden="true">
                                    <i class="ti ti-filter"></i>
                                </span>
                                <div class="rr-custom-select" id="rr_member_filter_custom">
                                    <label class="visually-hidden" for="rr_member_filter_trigger">{{ __('Member filter', 'roundrobin') }}</label>
                                    <button type="button"
                                            class="rr-custom-select__trigger"
                                            id="rr_member_filter_trigger"
                                            aria-haspopup="listbox"
                                            aria-expanded="false"
                                            aria-controls="rr_member_filter_menu">
                                        <span class="rr-custom-select__label" id="rr_member_filter_label"></span>
                                        <i class="ti ti-chevron-down rr-custom-select__caret" aria-hidden="true"></i>
                                    </button>
                                    <ul class="dropdown-menu rr-custom-select__menu"
                                        id="rr_member_filter_menu"
                                        role="listbox"
                                        hidden>
                                        <li role="presentation">
                                            <button type="button"
                                                    class="dropdown-item rr-custom-select__option"
                                                    role="option"
                                                    data-value="all">
                                                {{ __('Show all', 'roundrobin') }}
                                            </button>
                                        </li>
                                        <li role="presentation">
                                            <button type="button"
                                                    class="dropdown-item rr-custom-select__option"
                                                    role="option"
                                                    data-value="with_members">
                                                {{ __('With active members only', 'roundrobin') }}
                                            </button>
                                        </li>
                                        <li role="presentation">
                                            <button type="button"
                                                    class="dropdown-item rr-custom-select__option"
                                                    role="option"
                                                    data-value="without_members">
                                                {{ __('Without members', 'roundrobin') }}
                                            </button>
                                        </li>
                                    </ul>
                                    <select id="rr_member_filter"
                                            class="visually-hidden"
                                            tabindex="-1"
                                            aria-hidden="true">
                                        <option value="all"{% if persisted_member_filter == 'all' %} selected="selected"{% endif %}>{{ __('Show all', 'roundrobin') }}</option>
                                        <option value="with_members"{% if persisted_member_filter == 'with_members' %} selected="selected"{% endif %}>{{ __('With active members only', 'roundrobin') }}</option>
                                        <option value="without_members"{% if persisted_member_filter == 'without_members' %} selected="selected"{% endif %}>{{ __('Without members', 'roundrobin') }}</option>
                                    </select>
                                </div>
                            </div>
                            <div class="rr-category-search-group" role="search">
                                <input type="text"
                                       class="form-control"
                                       id="rr_category_search"
                                       value="{{ persisted_search|e('html_attr') }}"
                                       placeholder="{{ search_placeholder|e('html_attr') }}"
                                       aria-label="{{ search_placeholder|e('html_attr') }}"
                                       autocomplete="off"
                                       inputmode="search"/>
                                <span class="rr-category-search-group__action">
                                    <button type="button"
                                            class="btn btn-link p-0 m-0"
                                            id="rr_category_search_btn"
                                            title="{{ __('Search for category or group', 'roundrobin')|e('html_attr') }}">
                                        <span class="ti ti-search" aria-hidden="true"></span>
                                        <span class="visually-hidden">{{ __('Search for category or group', 'roundrobin') }}</span>
                                    </button>
                                </span>
                            </div>
                        </div>
                        <p id="rr_category_search_status" class="visually-hidden" aria-live="polite"></p>
                    </div>
                    <div id="rr_category_scroll" class="rr-category-scroll table-responsive-lg border-top">
                        <table id="plugin-rr-category-table" class="table table-hover table-striped table-sm align-middle mb-0">
                            {% set has_enableable_rows = false %}
                            {% for row in settings %}{% if row.can_enable_roundrobin %}{% set has_enableable_rows = true %}{% endif %}{% endfor %}
                            <thead class="table-light">
                            <tr>
                                <th scope="col">{{ __('ITIL category', 'roundrobin') }}</th>
                                <th scope="col">{{ __('Technician group', 'roundrobin') }}</th>
                                <th scope="col">{{ __('Active members', 'roundrobin') }}</th>
                                <th scope="col">
                                    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 gap-md-3">
                                        <span class="me-1">{{ __('Settings', 'roundrobin') }}</span>
                                        {% if can_write and has_enableable_rows %}
                                            <div class="form-check form-switch d-flex align-items-center gap-2 mb-0 ms-auto"
                                                 style="text-transform:none;letter-spacing:0;">
                                                <input class="form-check-input flex-shrink-0 m-0"
                                                       role="switch"
                                                       type="checkbox"
                                                       id="rr_select_all_sw"
                                                       aria-label="{{ __('Select all', 'roundrobin')|e('html_attr') }}"/>
                                                <label class="form-check-label small fw-normal text-secondary mb-0"
                                                       for="rr_select_all_sw">{{ __('Select all', 'roundrobin') }}</label>
                                            </div>
                                        {% endif %}
                                    </div>
                                </th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for row in settings %}
                                {% set group_search = row.group_name|default('')|trim %}
                                {% if group_search is empty %}
                                    {% set group_search = no_group_label %}
                                {% endif %}
                                <tr class="rr-category-row"
                                    data-rr-search="{{ (row.category_name ~ ' ' ~ group_search)|lower|e('html_attr') }}"
                                    data-rr-has-group="{{ row.groups_id > 0 ? 1 : 0 }}"
                                    data-rr-members="{{ row.groups_id > 0 ? row.num_group_members|default(0) : 0 }}">
                                    <td>
                                        {% if row.category_url %}
                                            <a href="{{ row.category_url|e('html_attr') }}" class="rr-item-link">{{ row.category_name|e }}</a>
                                        {% else %}
                                            {{ row.category_name|e }}
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if row.group_url %}
                                            <a href="{{ row.group_url|e('html_attr') }}" class="rr-item-link">{{ row.group_name|e }}</a>
                                        {% elseif row.group_name %}
                                            {{ row.group_name|e }}
                                        {% else %}
                                            <span class="text-muted fst-italic">{{ __('No technician group assigned', 'roundrobin') }}</span>
                                        {% endif %}
                                    </td>
                                    <td class="text-secondary">
                                        {% if row.groups_id > 0 %}
                                            {{ row.num_group_members|default(0) }}
                                        {% else %}
                                            <span class="text-muted">{{ __('N/A', 'roundrobin') }}</span>
                                        {% endif %}
                                    </td>
                                    <td class="lh-sm">
                                        <input type="hidden" name="itilcategories_id_{{ row.id }}" value="{{ row.itilcategories_id }}"/>

                                        {% if row.can_enable_roundrobin %}
                                            <input type="hidden" name="is_active_{{ row.id }}" value="0"/>
                                            <div class="form-check form-switch mb-0">
                                                <input class="form-check-input rr-toggle"
                                                       role="switch"
                                                       type="checkbox"
                                                       name="is_active_{{ row.id }}"
                                                       value="1"
                                                       id="rr_sw_{{ row.id }}"
                                                       data-rr-on="{{ __('Enabled', 'roundrobin')|e('html_attr') }}"
                                                       data-rr-off="{{ __('Disabled', 'roundrobin')|e('html_attr') }}"
                                                       {% if row.is_active %}checked="checked"{% endif %}
                                                       {% if not can_write %}disabled{% endif %} />
                                                <label class="form-check-label rr-toggle-label" for="rr_sw_{{ row.id }}">{% if row.is_active %}{{ __('Enabled', 'roundrobin') }}{% else %}{{ __('Disabled', 'roundrobin') }}{% endif %}</label>
                                            </div>
                                        {% else %}
                                            <input type="hidden" name="is_active_{{ row.id }}" value="0"/>
                                            <div class="form-check form-switch mb-1">
                                                <input class="form-check-input"
                                                       type="checkbox"
                                                       disabled
                                                       role="switch"
                                                       {% if row.is_active %}checked="checked"{% endif %}
                                                       id="rr_sw_disabled_{{ row.id }}"/>
                                                <label class="form-check-label text-muted" for="rr_sw_disabled_{{ row.id }}">{{ __('Disabled', 'roundrobin') }}</label>
                                            </div>
                                            <div class="form-text">{{ __('Assign a technician group on the ITIL category first.', 'roundrobin') }}</div>
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                    <p id="rr_category_no_results" class="rr-category-no-results text-muted small mb-0">
                        {{ __('No categories match your search.', 'roundrobin') }}
                    </p>
                {% endif %}
            </div>
            {% if settings is not empty %}
                <div id="rr_category_pager"
                     class="card-footer search-footer d-block"
                     data-showing="{{ __('Showing %s to %s of %s rows')|e('html_attr') }}"
                     data-showing-short="{{ __('%s-%s/%s')|e('html_attr') }}"
                     data-default-limit="{{ default_list_limit }}">
                    <div class="flex-grow-1 d-flex flex-wrap flex-md-nowrap align-items-center justify-content-between mb-0 search-pager">
                        <span class="search-limit d-none d-md-block">
                            <select id="rr_list_limit"
                                    class="form-select form-select-sm mx-1 d-inline-block w-auto search-limit-dropdown"
                                    aria-labelledby="rr_list_limit_label">
                                {% for value in page_limit_options %}
                                    <option value="{{ value }}"{% if value == default_list_limit %} selected="selected"{% endif %}>{{ value }}</option>
                                {% endfor %}
                            </select>
                            <span id="rr_list_limit_label">{{ __('rows / page') }}</span>
                        </span>
                        <span class="search-limit d-block d-md-none">
                            <select id="rr_list_limit_short"
                                    class="form-select form-select-sm mx-1 d-inline-block w-auto search-limit-dropdown"
                                    aria-label="{{ __('Rows per page')|e('html_attr') }}">
                                {% for value in page_limit_options %}
                                    <option value="{{ value }}"{% if value == default_list_limit %} selected="selected"{% endif %}>{{ value }}</option>
                                {% endfor %}
                            </select>
                        </span>
                        <p id="rr_page_infos_desktop" class="m-0 text-muted d-none d-md-block page-infos"></p>
                        <p id="rr_page_infos_mobile" class="m-0 text-muted d-block d-md-none text-nowrap ms-2 page-infos"></p>
                        <ul id="rr_category_pagination" class="pagination m-0 mt-sm-2 mt-md-0 align-items-center"></ul>
                    </div>
                </div>
            {% endif %}
        </div>

{% endif %}

    {% if can_write %}
        <div class="d-flex justify-content-end mt-2 mb-4">
            <button type="submit" name="save_config" value="1" class="btn btn-primary py-2 px-4">
                <i class="ti ti-device-floppy me-1" aria-hidden="true"></i>{{ __('Save', 'roundrobin') }}
            </button>
        </div>
    {% endif %}
</form>

{% if centralInterfaceCheck %}
    <script>
        (function () {
            var root = document.querySelector('.plugin-roundrobin-config');
            if (!root) {
                return;
            }

            var pagerRoot = document.getElementById('rr_category_pager');
            var searchInput = document.getElementById('rr_category_search');
            var searchButton = document.getElementById('rr_category_search_btn');
            var noResults = document.getElementById('rr_category_no_results');
            var rows = Array.prototype.slice.call(root.querySelectorAll('.rr-category-row'));
            var toggles = Array.prototype.slice.call(root.querySelectorAll('.rr-toggle'));
            var selectAll = document.getElementById('rr_select_all_sw');
            var limitSelect = document.getElementById('rr_list_limit');
            var limitSelectShort = document.getElementById('rr_list_limit_short');
            var limitPersist = document.getElementById('rr_list_limit_persist');
            var searchPersist = document.getElementById('rr_category_search_persist');
            var pagePersist = document.getElementById('rr_current_page_persist');
            var memberFilterPersist = document.getElementById('rr_member_filter_persist');
            var memberFilter = document.getElementById('rr_member_filter');
            var memberFilterCustom = document.getElementById('rr_member_filter_custom');
            var memberFilterTrigger = document.getElementById('rr_member_filter_trigger');
            var memberFilterMenu = document.getElementById('rr_member_filter_menu');
            var memberFilterLabel = document.getElementById('rr_member_filter_label');
            var memberFilterOptions = memberFilterMenu
                ? Array.prototype.slice.call(memberFilterMenu.querySelectorAll('.rr-custom-select__option'))
                : [];
            var formRoot = document.querySelector('.plugin-roundrobin-config__form');
            var pageInfosDesktop = document.getElementById('rr_page_infos_desktop');
            var pageInfosMobile = document.getElementById('rr_page_infos_mobile');
            var pagination = document.getElementById('rr_category_pagination');
            var scrollWrap = document.getElementById('rr_category_scroll');

            if (!rows.length || !pagerRoot) {
                return;
            }

            var showingTemplate = pagerRoot.getAttribute('data-showing') || 'Showing %s to %s of %s rows';
            var showingShortTemplate = pagerRoot.getAttribute('data-showing-short') || '%s-%s/%s';
            var currentPage = formRoot ? parseInt(formRoot.getAttribute('data-persisted-page') || '1', 10) : 1;
            var pageSize = parseInt(pagerRoot.getAttribute('data-default-limit') || '20', 10);
            if (!currentPage || currentPage < 1) {
                currentPage = 1;
            }
            if (!pageSize || pageSize < 1) {
                pageSize = 20;
            }

            function refreshLabel(cb) {
                var label = document.querySelector('label[for="' + cb.id + '"].rr-toggle-label');
                if (!label) {
                    return;
                }
                label.textContent = cb.checked ? cb.dataset.rrOn : cb.dataset.rrOff;
            }

            function formatTemplate(template, start, end, total) {
                var values = [start, end, total];
                var index = 0;

                return template.replace(/%(\d+\$)?s/g, function () {
                    var value = values[index];
                    index += 1;
                    return value !== undefined ? String(value) : '';
                });
            }

            function syncPersistedState() {
                if (searchPersist && searchInput) {
                    searchPersist.value = searchInput.value;
                }
                if (pagePersist) {
                    pagePersist.value = String(currentPage);
                }
                if (memberFilterPersist && memberFilter) {
                    memberFilterPersist.value = memberFilter.value;
                }
            }

            function rowMatchesMemberFilter(row) {
                if (!memberFilter || memberFilter.value === 'all') {
                    return true;
                }

                var hasGroup = row.getAttribute('data-rr-has-group') === '1';
                var members = parseInt(row.getAttribute('data-rr-members') || '0', 10);

                if (memberFilter.value === 'with_members') {
                    return hasGroup && members > 0;
                }

                if (memberFilter.value === 'without_members') {
                    return !hasGroup || members === 0;
                }

                return true;
            }

            function hasActiveFilters() {
                var hasSearch = searchInput && searchInput.value.trim() !== '';
                var hasMemberFilter = memberFilter && memberFilter.value !== 'all';
                return hasSearch || hasMemberFilter;
            }
            function matchingRows() {
                return rows.filter(function (row) {
                    return !row.classList.contains('rr-category-row--hidden');
                });
            }

            function visibleToggles() {
                return toggles.filter(function (cb) {
                    var row = cb.closest('.rr-category-row');
                    return row
                        && !row.classList.contains('rr-category-row--hidden')
                        && !row.classList.contains('rr-category-row--paged-out')
                        && !cb.disabled;
                });
            }

            function syncLimitSelects(value) {
                if (limitSelect) {
                    limitSelect.value = String(value);
                }
                if (limitSelectShort) {
                    limitSelectShort.value = String(value);
                }
                if (limitPersist) {
                    limitPersist.value = String(value);
                }
            }

            function updatePageInfos(start, end, total) {
                var desktopText = formatTemplate(showingTemplate, start, end, total);
                var mobileText = formatTemplate(showingShortTemplate, start, end, total);
                if (pageInfosDesktop) {
                    pageInfosDesktop.textContent = desktopText;
                }
                if (pageInfosMobile) {
                    pageInfosMobile.textContent = mobileText;
                }
            }

            function addPageButton(page, label, disabled, active, title) {
                var li = document.createElement('li');
                li.className = 'page-item' + (disabled ? ' disabled' : '') + (active ? ' active' : '');

                var btn = document.createElement('button');
                btn.type = 'button';
                btn.className = 'page-link d-flex align-items-center justify-content-center';
                btn.textContent = label;
                if (title) {
                    btn.title = title;
                }
                if (!disabled && !active) {
                    btn.addEventListener('click', function () {
                        currentPage = page;
                        applyPagination();
                        syncPersistedState();
                    });
                }
                if (disabled) {
                    btn.setAttribute('aria-disabled', 'true');
                }
                if (active) {
                    btn.setAttribute('aria-current', 'page');
                }

                li.appendChild(btn);
                pagination.appendChild(li);
            }

            function addPageIconButton(page, iconClass, disabled, title) {
                var li = document.createElement('li');
                li.className = 'page-item' + (disabled ? ' disabled' : '');

                var btn = document.createElement('button');
                btn.type = 'button';
                btn.className = 'page-link d-flex align-items-center justify-content-center';
                btn.title = title;
                btn.innerHTML = '<i class="' + iconClass + '"></i>';
                if (!disabled) {
                    btn.addEventListener('click', function () {
                        currentPage = page;
                        applyPagination();
                        syncPersistedState();
                    });
                } else {
                    btn.setAttribute('aria-disabled', 'true');
                }

                li.appendChild(btn);
                pagination.appendChild(li);
            }

            function renderPaginationControls(totalPages) {
                if (!pagination) {
                    return;
                }

                pagination.innerHTML = '';
                if (totalPages <= 1) {
                    return;
                }

                var adjacents = 2;
                var skipAdjacents = false;

                addPageIconButton(1, 'ti ti-chevrons-left', currentPage <= 1, 'Start');
                addPageIconButton(currentPage - 1, 'ti ti-chevron-left', currentPage <= 1, 'Previous');

                for (var page = 1; page <= totalPages; page += 1) {
                    if (page >= currentPage - adjacents && page <= currentPage + adjacents) {
                        addPageButton(page, String(page), false, page === currentPage);
                        skipAdjacents = false;
                    } else if (!skipAdjacents) {
                        skipAdjacents = true;
                        var ellipsis = document.createElement('li');
                        ellipsis.className = 'page-item disabled';
                        var span = document.createElement('span');
                        span.className = 'page-link';
                        span.textContent = '...';
                        ellipsis.appendChild(span);
                        pagination.appendChild(ellipsis);
                    }
                }

                addPageIconButton(currentPage + 1, 'ti ti-chevron-right', currentPage >= totalPages, 'Next');
                addPageIconButton(totalPages, 'ti ti-chevrons-right', currentPage >= totalPages, 'End');
            }

            function syncScrollState(visibleOnPage) {
                if (!scrollWrap) {
                    return;
                }
                scrollWrap.classList.toggle('is-scrollable', visibleOnPage > 5);
            }

            function applyPagination() {
                var matched = matchingRows();
                var total = matched.length;
                var totalPages = Math.max(1, Math.ceil(total / pageSize));

                if (currentPage > totalPages) {
                    currentPage = totalPages;
                }
                if (currentPage < 1) {
                    currentPage = 1;
                }

                var startIdx = (currentPage - 1) * pageSize;
                var endIdx = Math.min(startIdx + pageSize, total);

                rows.forEach(function (row) {
                    row.classList.remove('rr-category-row--paged-out');
                });

                matched.forEach(function (row, idx) {
                    if (idx < startIdx || idx >= endIdx) {
                        row.classList.add('rr-category-row--paged-out');
                    }
                });

                var displayStart = total === 0 ? 0 : startIdx + 1;
                var displayEnd = total === 0 ? 0 : endIdx;
                var visibleOnPage = total === 0 ? 0 : endIdx - startIdx;

                updatePageInfos(displayStart, displayEnd, total);
                renderPaginationControls(totalPages);
                syncScrollState(visibleOnPage);
                syncSelectAllState();
                syncPersistedState();

                if (noResults) {
                    noResults.classList.toggle('is-visible', hasActiveFilters() && total === 0);
                }
            }

            function applyFilters(resetPage) {
                var query = searchInput ? searchInput.value.trim().toLowerCase() : '';

                rows.forEach(function (row) {
                    var haystack = row.getAttribute('data-rr-search') || '';
                    var searchMatch = query === '' || haystack.indexOf(query) !== -1;
                    var memberMatch = rowMatchesMemberFilter(row);
                    row.classList.toggle('rr-category-row--hidden', !(searchMatch && memberMatch));
                });

                if (resetPage) {
                    currentPage = 1;
                }

                applyPagination();
            }

            function syncSelectAllState() {
                if (!selectAll) {
                    return;
                }

                var selectable = visibleToggles();
                if (!selectable.length) {
                    selectAll.checked = false;
                    return;
                }

                var checkedCount = selectable.filter(function (cb) { return cb.checked; }).length;
                selectAll.checked = checkedCount === selectable.length && checkedCount > 0;
            }

            function onLimitChange(value) {
                pageSize = parseInt(value, 10);
                if (!pageSize || pageSize < 1) {
                    pageSize = 20;
                }
                syncLimitSelects(pageSize);
                currentPage = 1;
                applyPagination();
            }

            toggles.forEach(function (cb) {
                cb.addEventListener('change', function () {
                    refreshLabel(cb);
                    syncSelectAllState();
                });
                refreshLabel(cb);
            });

            if (selectAll) {
                selectAll.addEventListener('change', function () {
                    var target = selectAll.checked;
                    visibleToggles().forEach(function (cb) {
                        if (cb.checked !== target) {
                            cb.checked = target;
                            refreshLabel(cb);
                        }
                    });
                });
            }

            function initSearchInputWidth() {
                if (!searchInput) {
                    return;
                }

                var probe = document.createElement('span');
                var styles = window.getComputedStyle(searchInput);
                probe.style.position = 'absolute';
                probe.style.visibility = 'hidden';
                probe.style.whiteSpace = 'pre';
                probe.style.font = styles.font;
                probe.style.letterSpacing = styles.letterSpacing;
                probe.textContent = searchInput.getAttribute('placeholder') || '';
                searchInput.parentNode.appendChild(probe);
                var width = Math.ceil(probe.getBoundingClientRect().width + 2) + 'px';
                searchInput.style.width = width;
                searchInput.style.minWidth = width;
                searchInput.style.flexBasis = width;
                probe.remove();
            }

            if (searchInput) {
                initSearchInputWidth();
                searchInput.addEventListener('input', function () {
                    applyFilters(true);
                });
                searchInput.addEventListener('keydown', function (event) {
                    if (event.key === 'Enter') {
                        event.preventDefault();
                        applyFilters(true);
                    }
                });
            }

            if (searchButton) {
                searchButton.addEventListener('click', function () {
                    applyFilters(true);
                    if (searchInput) {
                        searchInput.focus();
                    }
                });
            }

            if (memberFilter) {
                memberFilter.addEventListener('change', function () {
                    applyFilters(true);
                });
            }

            function syncMemberFilterUi() {
                if (!memberFilter) {
                    return;
                }

                var selectedValue = memberFilter.value;
                if (memberFilterLabel) {
                    var selectedOption = memberFilter.options[memberFilter.selectedIndex];
                    memberFilterLabel.textContent = selectedOption ? selectedOption.textContent : '';
                }

                memberFilterOptions.forEach(function (optionEl) {
                    var isSelected = optionEl.getAttribute('data-value') === selectedValue;
                    optionEl.classList.toggle('active', isSelected);
                    optionEl.setAttribute('aria-selected', isSelected ? 'true' : 'false');
                });
            }

            function closeMemberFilterMenu() {
                if (!memberFilterCustom || !memberFilterMenu || !memberFilterTrigger) {
                    return;
                }

                memberFilterCustom.classList.remove('is-open');
                memberFilterMenu.hidden = true;
                memberFilterTrigger.setAttribute('aria-expanded', 'false');
            }

            function openMemberFilterMenu() {
                if (!memberFilterCustom || !memberFilterMenu || !memberFilterTrigger) {
                    return;
                }

                memberFilterCustom.classList.add('is-open');
                memberFilterMenu.hidden = false;
                memberFilterTrigger.setAttribute('aria-expanded', 'true');
            }

            function toggleMemberFilterMenu() {
                if (!memberFilterMenu || memberFilterMenu.hidden) {
                    openMemberFilterMenu();
                } else {
                    closeMemberFilterMenu();
                }
            }

            function setMemberFilterValue(value) {
                if (!memberFilter) {
                    return;
                }

                memberFilter.value = value;
                syncMemberFilterUi();
                memberFilter.dispatchEvent(new Event('change', { bubbles: true }));
            }

            if (memberFilterTrigger) {
                memberFilterTrigger.addEventListener('click', function (event) {
                    event.preventDefault();
                    event.stopPropagation();
                    toggleMemberFilterMenu();
                });
            }

            memberFilterOptions.forEach(function (optionEl) {
                function chooseOption() {
                    setMemberFilterValue(optionEl.getAttribute('data-value') || 'all');
                    closeMemberFilterMenu();
                }

                optionEl.addEventListener('click', chooseOption);
                optionEl.addEventListener('keydown', function (event) {
                    if (event.key === 'Enter' || event.key === ' ') {
                        event.preventDefault();
                        chooseOption();
                    }
                });
            });

            document.addEventListener('click', function (event) {
                if (!memberFilterCustom || !memberFilterMenu || memberFilterMenu.hidden) {
                    return;
                }

                if (!memberFilterCustom.contains(event.target)) {
                    closeMemberFilterMenu();
                }
            });

            document.addEventListener('keydown', function (event) {
                if (event.key === 'Escape') {
                    closeMemberFilterMenu();
                }
            });

            syncMemberFilterUi();

            if (limitSelect) {
                limitSelect.addEventListener('change', function () {
                    onLimitChange(limitSelect.value);
                });
            }
            if (limitSelectShort) {
                limitSelectShort.addEventListener('change', function () {
                    onLimitChange(limitSelectShort.value);
                });
            }

            syncLimitSelects(pageSize);
            applyFilters(false);
        })();
    </script>

{% endif %}
