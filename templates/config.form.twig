<div class="container-fluid ps-0">

    {# ── Global option ──────────────────────────────────────────────────────── #}
    <div class="card mb-3">
        <div class="card-header">
            <h5 class="card-title mb-0">
                <i class="ti ti-settings me-2"></i>
                {{ __('Global options', 'roundrobin') }}
            </h5>
        </div>
        <div class="card-body">
            <form name="optionsForm" action="config.form.php" method="post">
                {{ csrf_token|raw }}
                <input type="hidden" name="action" value="save_options">

                <div class="d-flex align-items-center gap-3">
                    <label class="form-label mb-0 fw-semibold" for="auto_assign_group">
                        {{ __('Assign also to the original Group:', 'roundrobin') }}
                    </label>
                    <div class="form-check form-switch mb-0">
                        <input class="form-check-input"
                               type="checkbox"
                               role="switch"
                               id="auto_assign_group"
                               name="auto_assign_group"
                               value="1"
                               {{ auto_assign_group ? 'checked' : '' }}>
                        <label class="form-check-label" for="auto_assign_group">
                            {{ __('Yes') }}
                        </label>
                    </div>
                </div>

                <div class="mt-3">
                    <button type="submit" name="save" class="btn btn-primary btn-sm">
                        <i class="ti ti-device-floppy me-1"></i>
                        {{ __('Save') }}
                    </button>
                </div>
            </form>
        </div>
    </div>

    {# ── Per-category table ─────────────────────────────────────────────────── #}
    <div class="card">
        <div class="card-header d-flex align-items-center justify-content-between">
            <h5 class="card-title mb-0">
                <i class="ti ti-rotate-clockwise me-2"></i>
                {{ __('Enable Round Robin per ITIL Category', 'roundrobin') }}
            </h5>
            <span class="badge bg-secondary">
                {{ settings|length }} {{ __('categories') }}
            </span>
        </div>

        <div class="card-body p-0">
            <form name="settingsForm" action="config.form.php" method="post">
                {{ csrf_token|raw }}
                <input type="hidden" name="action" value="save_categories">

                {% if settings is empty %}
                    <div class="text-center py-5 text-muted">
                        <i class="ti ti-inbox fs-1 d-block mb-2"></i>
                        {{ __('No ITIL categories found.', 'roundrobin') }}
                    </div>
                {% else %}
                    <div class="table-responsive">
                        <table class="table table-hover table-striped mb-0">
                            <thead>
                                <tr>
                                    <th>{{ __('ITIL Category', 'roundrobin') }}</th>
                                    <th>{{ __('Group', 'roundrobin') }}</th>
                                    <th class="text-center">{{ __('Members', 'roundrobin') }}</th>
                                    <th class="text-center">{{ __('Round Robin', 'roundrobin') }}</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for row in settings %}
                                    <tr class="{{ row.is_active ? '' : 'text-muted' }}">

                                        <td>
                                            <input type="hidden"
                                                   name="itilcategories_id_{{ row.id|e }}"
                                                   value="{{ row.itilcategories_id|e }}">
                                            {{ row.category_name|e }}
                                        </td>

                                        <td>
                                            {% if row.group_name %}
                                                <span class="badge bg-info text-dark">
                                                    <i class="ti ti-users me-1"></i>
                                                    {{ row.group_name|e }}
                                                </span>
                                            {% else %}
                                                <em class="text-muted">
                                                    {{ __('No group assigned', 'roundrobin') }}
                                                </em>
                                            {% endif %}
                                        </td>

                                        <td class="text-center">
                                            {% if row.group_name is not null %}
                                                <span class="badge {{ row.num_group_members > 0 ? 'bg-success' : 'bg-warning text-dark' }}">
                                                    {{ row.num_group_members|e }}
                                                </span>
                                            {% else %}
                                                <span class="text-muted">—</span>
                                            {% endif %}
                                        </td>

                                        <td class="text-center">
                                            {% if row.group_name is not null and row.num_group_members > 0 %}
                                                <div class="form-check form-switch d-flex justify-content-center mb-0">
                                                    <input class="form-check-input"
                                                           type="checkbox"
                                                           role="switch"
                                                           id="is_active_{{ row.id|e }}"
                                                           name="is_active_{{ row.id|e }}"
                                                           value="1"
                                                           {{ row.is_active ? 'checked' : '' }}>
                                                </div>
                                            {% else %}
                                                <span class="text-muted"
                                                      title="{{ __('Requires a group with at least one active member', 'roundrobin') }}">
                                                    <i class="ti ti-ban"></i>
                                                </span>
                                            {% endif %}
                                        </td>

                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>

                    <div class="d-flex justify-content-end gap-2 p-3 border-top">
                        <a href="config.form.php" class="btn btn-outline-secondary btn-sm">
                            <i class="ti ti-x me-1"></i>
                            {{ __('Cancel') }}
                        </a>
                        <button type="submit" name="save" class="btn btn-primary btn-sm">
                            <i class="ti ti-device-floppy me-1"></i>
                            {{ __('Save') }}
                        </button>
                    </div>
                {% endif %}

            </form>
        </div>
    </div>

</div>
